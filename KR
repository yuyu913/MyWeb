<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>韓國行程整理 🇰🇷</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    :root {
      --bg: #fff7fb;
      --card: rgba(255,255,255,.9);
      --stroke: rgba(16,24,40,.08);
      --text: #1f2937;
      --muted: #6b7280;
      --food-bg: rgba(255, 111, 177, .12);
      --food-bd: rgba(255, 111, 177, .28);
      --food-tx: #7a284f;
      --spot-bg: rgba(107, 199, 255, .14);
      --spot-bd: rgba(107, 199, 255, .32);
      --spot-tx: #0f3a56;
      --shop-bg: rgba(255, 211, 77, .20);
      --shop-bd: rgba(255, 211, 77, .45);
      --shop-tx: #6b4b00;
      --note-bg: rgba(16, 24, 40, .05);
      --note-bd: rgba(16, 24, 40, .10);
      --note-tx: #374151;
      --shadow: 0 10px 30px rgba(16,24,40,.08);
    }
    body {
      background:
        radial-gradient(1200px 600px at 10% 0%, rgba(255, 111, 177, .14), transparent 50%),
        radial-gradient(900px 500px at 90% 10%, rgba(107, 199, 255, .16), transparent 50%),
        radial-gradient(1000px 600px at 50% 100%, rgba(255, 211, 77, .14), transparent 50%),
        var(--bg);
      color: var(--text);
    }
    .app-shell{max-width:1100px;margin:24px auto 60px;padding:0 14px;}
    .hero{
      border:1px solid var(--stroke);
      background:rgba(255,255,255,.75);
      backdrop-filter: blur(10px);
      border-radius:22px;
      box-shadow:var(--shadow);
      overflow:hidden;
      position:relative;
      margin-bottom:18px;
    }
    .hero::before{
      content:"";position:absolute;inset:-2px;
      background:linear-gradient(90deg, rgba(255, 111, 177, .22), rgba(107, 199, 255, .22), rgba(255, 211, 77, .22));
      filter:blur(18px);z-index:0;
    }
    .hero-inner{position:relative;padding:18px;background:rgba(255,255,255,.82);}
    .title{display:flex;gap:12px;align-items:center;flex-wrap:wrap;}
    .sparkle{width:44px;height:44px;border-radius:14px;display:grid;place-items:center;background:linear-gradient(135deg, rgba(255, 111, 177, .18), rgba(107, 199, 255, .18));border:1px solid var(--stroke);font-size:22px;}
    .legend{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px;}
    .chip{border:1px dashed rgba(255,111,177,.25);background:rgba(255,240,247,.7);color:#7a284f;border-radius:999px;padding:6px 10px;font-size:.88rem;display:flex;gap:6px;align-items:center;}
    .chip.blue{border-color:rgba(107,199,255,.30);background:rgba(107,199,255,.12);color:#0f3a56;}
    .chip.yellow{border-color:rgba(255,211,77,.45);background:rgba(255,211,77,.18);color:#6b4b00;}
    .chip.gray{border-color:rgba(16,24,40,.12);background:rgba(16,24,40,.04);color:#374151;}
    .day-card{border:1px solid var(--stroke);background:var(--card);backdrop-filter: blur(10px);border-radius:18px;box-shadow:0 10px 26px rgba(16,24,40,.06);overflow:hidden;}
    .day-header{padding:14px 16px;border-bottom:1px solid var(--stroke);background:linear-gradient(90deg, rgba(255,111,177,.10), rgba(107,199,255,.10), rgba(255,211,77,.10));display:flex;justify-content:space-between;align-items:flex-start;gap:12px;}
    .day-title h5{margin:0;font-weight:900;letter-spacing:.2px;}
    .day-sub{color:var(--muted);font-size:.92rem;margin-top:4px;}
    .pill{border-radius:999px;border:1px solid var(--stroke);background:rgba(255,255,255,.80);color:#374151;padding:6px 10px;font-size:.86rem;white-space:nowrap;display:inline-flex;gap:6px;align-items:center;}
    .pill.blue{border-color:var(--spot-bd);background:var(--spot-bg);color:var(--spot-tx);}
    .timeline{position:relative;--time-col:120px;--time-text:84px;--bullet:8px;--line-x:calc(var(--time-col) - (var(--bullet) / 2) - 1px);padding:12px 14px 16px;}
    .timeline::before{content:"";position:absolute;left:var(--line-x);top:20px;bottom:20px;width:2px;z-index:0;opacity:.55;background:repeating-linear-gradient(180deg, rgba(16,24,40,.12) 0, rgba(16,24,40,.12) 6px, transparent 6px, transparent 12px);}
    .t-item{display:grid;grid-template-columns:var(--time-col) 1fr;gap:10px;padding:3px 0;position:relative;z-index:1;}
    .t-time{display:flex;justify-content:flex-end;align-items:center;gap:10px;min-width:0;}
    .time-pill{display:inline-block;width:var(--time-text);text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:.78rem;font-weight:900;color:rgba(107,114,128,.75);line-height:1.1;}
    .t-bullet{width:var(--bullet);height:var(--bullet);border-radius:999px;background:rgba(16,24,40,.12);}
    .t-content{border-radius:14px;padding:2px 10px;display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;}
    .tag{border-radius:999px;padding:7px 11px;font-size:.98rem;border:1px solid var(--stroke);background:rgba(255,255,255,.80);color:var(--text);display:inline-flex;align-items:center;line-height:1;white-space:nowrap;}
    .tag.food{border-color:var(--food-bd);background:var(--food-bg);color:var(--food-tx);}
    .tag.spot{border-color:var(--spot-bd);background:var(--spot-bg);color:var(--spot-tx);}
    .tag.shop{border-color:var(--shop-bd);background:var(--shop-bg);color:var(--shop-tx);}
    .tag.note{border-color:var(--note-bd);background:var(--note-bg);color:var(--note-tx);}
    .t-note{color:var(--muted);font-size:.92rem;line-height:1.25;}
    .day-list{display:grid;gap:14px;}
    @media (max-width:576px){
      .timeline{--time-col:90px;--time-text:62px;}
      .time-pill{font-size:.72rem;}
      .t-content{padding-right:0;}
    }
  </style>
</head>
<body>
